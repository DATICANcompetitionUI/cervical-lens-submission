{
  "name": "cervical-lens",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter @cervical-lens/api",
    "dev:web": "turbo dev --filter @cervical-lens/web",
    "dev:mobile": "turbo dev --filter @cervical-lens/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "postinstall": "node patch-gradle-files.js"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "turbo": "^2.4.0"
  },
  "packageManager": "bun@1.2.0",
  "trustedDependencies": [
    "onnxruntime-node"
  ]
}
